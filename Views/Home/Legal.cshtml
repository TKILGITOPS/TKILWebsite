@{
    ViewData["Title"] = "Legal Notes";
}
<style>
    

    /* Tablet */
    @@media (max-width: 768px) {
        .legal-section

    {
        padding: 2rem 4vw;
    }

    .legal-nav {
        padding: 1rem;
    }

    }

    /* Mobile */
    @@media (max-width: 480px) {
        .legal-section

    {
        padding: 1.5rem 5vw;
    }

    .legal-heading {
        font-size: 1rem;
    }

    .legal-section p {
        font-size: 0.82rem;
    }

    .legal-nav-item {
        font-size: 0.78rem;
        padding: 0.3rem 0.7rem;
    }

    }
</style>
<div class="nd-hero">
    <div class="nd-hero-overlay">
        <div class="nd-hero-content">
            <span class="nd-eyebrow">Legal</span>
            <h1 class="nd-hero-title">Legal Notes</h1>
            <p class="nd-hero-sub">TKIL Industries Pvt. Ltd. — Privacy Policy &amp; Legal Information</p>
        </div>
    </div>
</div>

<div class="nd-page">
    <div style="max-width:100%; margin:0; padding:3rem 5vw;">
