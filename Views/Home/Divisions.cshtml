        };

            const divHeroImgs = {
            sugar:            '/images/divisions/SugarOverview.jpg',
            mining:           '/images/divisions/MiningOverview.jpg',
            cement:           '/images/divisions/Cementoverview.jpg',
            energy:           '/images/divisions/EnergyOverview.png',
            service:          '/images/divisions/ServiceOverview.jpg',
            'green-hydrogen': '/images/divisions/GreenHydroOverview.png',
            battery:          '/images/divisions/BatteryOverview.jpg'
        };

        // State
        let currentDivision = null;
        let currentProductItem = null;  // the top-level item clicked
        let currentSubIndex = 0;        // index within children if any

        // ── Helpers ──
        function extractFirstImg(html) {
            if (!html) return null;
            const m = html.match(/src="([^"]+)"/);
            return m ? m[1] : null;
        }

        function getFallbackImg() {
            return divHeroImgs[currentDivision] || '';
        }

        // Get all top-level items (for the card grid) — items with children show as a group card
        function getTopLevelItems(division) {
            const data = prdData[division];
            return data ? data.items : [];
        }

        // ── Build product card grid into a container ──
        function buildProductCards(items, container, onClickItem) {
            container.innerHTML = '';

            const heading = document.createElement('h3');
            heading.className = 'div-prd-cards-heading';
            heading.textContent = 'Products';
            container.appendChild(heading);

            const grid = document.createElement('div');
            grid.className = 'div-prd-cards-grid';

            for (const item of items) {
                const card = document.createElement('div');
                card.className = 'div-prd-card';

                // Get a bg image: either from first child's content, or item content, or fallback
                let bgImg = '';
                if (item.children && item.children.length) {
                    // Try to find first image from any leaf
                    const firstLeaf = flattenLeaves([item])[0];
                    bgImg = firstLeaf ? (extractFirstImg(firstLeaf.content) || getFallbackImg()) : getFallbackImg();
                } else {
                    bgImg = extractFirstImg(item.content) || getFallbackImg();
                }

                card.style.setProperty('--bg', `url('${bgImg}')`);

                const overlay = document.createElement('div');
                overlay.className = 'div-prd-card-overlay';

                const title = document.createElement('span');
                title.className = 'div-prd-card-title';
                title.textContent = item.title;

                card.appendChild(overlay);
                card.appendChild(title);
                card.addEventListener('click', () => onClickItem(item));
                grid.appendChild(card);
            }

            container.appendChild(grid);
        }

        function flattenLeaves(items) {
            const leaves = [];
            for (const item of items) {
                if (item.children && item.children.length) {
                    leaves.push(...flattenLeaves(item.children));
                } else if (item.content) {
                    leaves.push(item);
                }
            }
            return leaves;
        }

        // ── LEVEL 1 → LEVEL 2: Show division ──
        function showDetail(target) {
           
            currentDivision = target;
            currentProductItem = null;

            document.getElementById('divGrid').style.display    = 'none';
            document.getElementById('pageHero').style.display   = 'none';
            document.getElementById('divDetail').style.display  = 'block';
            document.getElementById('prdDetailView').style.display = 'none';

            // Show correct division panel
            document.querySelectorAll('#divisionPanels .nd-panel').forEach(p => p.style.display = 'none');
            const panel = document.querySelector(`#divisionPanels .nd-panel[data-section="${target}"]`);
            if (panel) panel.style.display = 'block';

            // Build product cards in this division's card container
            const data = prdData[target];
            const cardsContainer = document.getElementById(`${target}-cards`);
            if (data && data.items && data.items.length && cardsContainer) {
                buildProductCards(data.items, cardsContainer, (item) => showProductDetail(item));
            }

            // Back button → go to divisions grid
         

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ── LEVEL 2 → LEVEL 3: Show product detail ──
        function showProductDetail(item) {
            document.body.classList.add('on-detail-page');
            currentProductItem = item;
            currentSubIndex = 0;

            // Hide division panels, show product detail view
            document.getElementById('divisionPanels').style.display = 'none';
            document.getElementById('prdDetailView').style.display  = 'block';

            // If item has children, show first child with prev/next
            if (item.children && item.children.length) {
                renderSubProduct(item, 0);
            } else {
                // Direct content
                renderDirectProduct(item);
            }

            // Rebuild the same product cards below
            const repeatContainer = document.getElementById('prdDetailCardsRepeat');
            const data = prdData[currentDivision];
            if (data) {
                buildProductCards(data.items, repeatContainer, (clickedItem) => showProductDetail(clickedItem));
            }

            // Back button → go back to division page
         
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function getDivisionTitle(division) {
            const titles = {
                sugar: 'Sugar & Cogen',
                mining: 'Mining & MHE',
                cement: 'Cement',
                energy: 'Energy',
                service: 'Service',
                'green-hydrogen': 'Green Hydrogen',
                battery: 'Battery & Energy Storage'
            };
            return titles[division] || 'Division';
        }

        function renderDirectProduct(item) {
            document.getElementById('prdParentLabel').textContent = '';
            document.getElementById('prdDetailTitle').textContent = item.title;
            document.getElementById('prdDetailContent').innerHTML = item.content || '';

                    buildThumbStrip(item.content);
        if (!extractFirstImg(item.content)) {
            document.getElementById('prdDetailImg').src = getFallbackImg();
        }

            document.getElementById('prdSubnav').style.display = 'none';
            wireAccordions();
        }

        function renderSubProduct(parentItem, index) {
            // Flatten all leaf children (handles 2 levels deep)
            const leaves = flattenLeaves(parentItem.children ? [parentItem] : []);
            // But we want the direct children first — if a child has its own children, treat it as a group
            // Use direct children for prev/next
            const children = parentItem.children;
            currentSubIndex = index;

            const child = children[index];

            // If child itself has children, show first leaf
            let displayItem = child;
            let actualContent = child.content;
            if (!actualContent && child.children) {
                displayItem = flattenLeaves([child])[0] || child;
                actualContent = displayItem ? displayItem.content : '';
            }

            document.getElementById('prdParentLabel').textContent = parentItem.title;
            document.getElementById('prdDetailTitle').textContent = child.title;
            document.getElementById('prdDetailContent').innerHTML = actualContent || '';

                  buildThumbStrip(actualContent);
        if (!extractFirstImg(actualContent)) {
            document.getElementById('prdDetailImg').src = getFallbackImg();
        }

            // Prev/Next
            const subnav = document.getElementById('prdSubnav');
            subnav.style.display = 'flex';
            document.getElementById('prdSubnavInfo').textContent = `${index + 1} / ${children.length}`;

            const prevBtn = document.getElementById('prdPrevBtn');
            const nextBtn = document.getElementById('prdNextBtn');
            prevBtn.disabled = index === 0;
            nextBtn.disabled = index === children.length - 1;

            prevBtn.onclick = () => renderSubProduct(parentItem, index - 1);
            nextBtn.onclick = () => renderSubProduct(parentItem, index + 1);

            wireAccordions();
        }

              function wireAccordions() {
            document.querySelectorAll('#prdDetailContent .prd-acc-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const body = btn.nextElementSibling;
                    const span = btn.querySelector('span');
                    body.classList.toggle('open');
                    if (span) span.textContent = body.classList.contains('open') ? '−' : '+';
                });
            });
            // Right image → lightbox
            const mainImg = document.getElementById('prdDetailImg');
            mainImg.style.cursor = 'zoom-in';
            mainImg.onclick = () => { if (mainImg.src) openLightbox(mainImg.src); };
        }
        // ── Back to divisions grid ──
        function showGrid() {
            document.body.classList.remove('on-detail-page');
            document.getElementById('divGrid').style.display    = '';
            document.getElementById('pageHero').style.display   = '';
            document.getElementById('divDetail').style.display  = 'none';
            document.getElementById('divisionPanels').style.display = '';
            history.pushState(null, '', window.location.pathname);
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

               document.addEventListener('DOMContentLoaded', () => {

            // ── Single delegated handler for ALL back buttons ──
            document.addEventListener('click', function(e) {
                const btn = e.target.closest('.js-div-back-btn');
                if (!btn) return;

                if (currentProductItem) {
                    // Level 3 → Level 2
                    showDetail(currentDivision);
                } else {
                    // Level 2 → Level 1
                    showGrid();
                }
            });

            document.querySelectorAll('#divGrid .div-card[data-target]').forEach(card => {
                card.addEventListener('click', () => {
                    const target = card.dataset.target;
                    history.pushState(null, '', '#' + target);
                    showDetail(target);
                });
            });

            const hash = window.location.hash.replace('#', '');
            if (hash) showDetail(hash);

            window.addEventListener('popstate', () => {
                const h = window.location.hash.replace('#', '');
                if (h) showDetail(h);
                else showGrid();
            });
        });
                // ── Extract ALL image srcs from HTML string ──
        function extractAllImgs(html) {
            if (!html) return [];
            const matches = [...html.matchAll(/src="([^"]+)"/g)];
            return matches.map(m => m[1]);
        }

        // ── Build thumbnail strip and wire right-panel image ──
                function buildThumbStrip(html) {
            const mainImg = document.getElementById('prdDetailImg');
            const strip = document.getElementById('prdThumbStrip');
            strip.style.display = 'none';

            const imgs = extractAllImgs(html);
            if (imgs.length === 0) {
                mainImg.src = getFallbackImg();
                return;
            }

            // Set first image on right panel
            mainImg.src = imgs[0];

            // Wire inline content images to switch the right panel image
            // Run after content is rendered (short delay for DOM)
            setTimeout(() => {
                const contentEl = document.getElementById('prdDetailContent');
                if (!contentEl) return;
                const inlineImgs = contentEl.querySelectorAll('img');
                inlineImgs.forEach((img, i) => {
                    img.style.cursor = 'pointer';
                    img.style.border = '2px solid transparent';
                    img.style.borderRadius = '8px';
                    img.style.transition = 'border-color 0.2s, opacity 0.2s';
                    img.style.opacity = i === 0 ? '1' : '0.65';
                    img.style.borderColor = i === 0 ? '#1a6abf' : 'transparent';

                    img.addEventListener('click', () => {
                        mainImg.src = imgs[i] || img.src;
                        inlineImgs.forEach(im => {
                            im.style.opacity = '0.65';
                            im.style.borderColor = 'transparent';
                        });
                        img.style.opacity = '1';
                        img.style.borderColor = '#1a6abf';
                    });
                });
            }, 50);
        }

        // ── Lightbox ──
            function openLightbox(src) {
            document.getElementById('imgLightboxImg').src = src;
            const lb = document.getElementById('imgLightbox');
            lb.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            // Click backdrop to close
            lb.onclick = function(e) {
                if (e.target === lb) closeLightbox();
            };
        }
        function closeLightbox() {
            document.getElementById('imgLightbox').style.display = 'none';
            document.body.style.overflow = '';
        }
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
    </script>
}