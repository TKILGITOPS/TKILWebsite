<!-- ═══ DETAIL VIEW ═══ -->
<!-- ═══ DETAIL VIEW ═══ -->
<div id="divDetail" style="display:none;">

    <!-- Back button — label changes based on level -->
  

    <!-- ══ LEVEL 2: Division panels (hero + product cards) ══ -->
    <div id="divisionPanels">

        <div class="nd-panel" data-section="sugar" style="display:none;">
            <div class="div-hero-split">
                <img src="~/images/Divisions/SugarOverview.jpg" alt="Sugar" class="div-hero-split-img" />
                <button class="div-back-btn js-div-back-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7" /></svg>
                    <span id="divBackLabel">Back to Divisions</span>
                </button>
                <div class="div-hero-split-card">
                   
                    <h2 class="div-split-title">Sugar &amp; Cogen</h2>
