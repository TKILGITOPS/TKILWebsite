@{
    ViewData["Title"] = "Divisions";
}

<style>
    /* ── Card Grid Page ── */
    .div-grid-page {
        background: #f4f6f9;
        padding: 2rem 5vw 2.5rem;
    }

    .div-card-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
        max-width: 1300px;
        margin: 0 auto;
    }

    /* ── Division Card ── */

    .div-card {
        position: relative;
        background: #fff;
        border-radius: 14px;
        overflow: hidden;
        cursor: pointer;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        border: 1.5px solid #e8edf4;
        padding-bottom: 1rem;
    }

        .div-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 36px rgba(0,80,200,0.13);
            border-color: #1a6abf;
        }

    .div-card-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0;
        transition: opacity 0.35s ease;
        filter: blur(1px);
    }

    .div-card:hover .div-card-bg {
        opacity: 1;
    }

    .div-card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(160deg, rgba(10,50,120,0.82) 0%, rgba(0,110,200,0.70) 100%);
        opacity: 0;
        transition: opacity 0.35s ease;
    }

    .div-card:hover .div-card-overlay {
        opacity: 0.72;
    }

    .div-card-body {
        position: relative;
        z-index: 2;
        padding: 1.25rem 1.25rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
    }

    .div-card-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #111827;
        line-height: 1.35;
        margin: 0 0 0.75rem;
        transition: color 0.3s ease;
    }

    .div-card:hover .div-card-title {
        color: #fff;
    }

    .div-card-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: #0079A7;
        margin-top: 0.25rem;
        cursor: pointer;
        text-decoration: none;
    }

    .div-card:hover .div-card-cta {
        color: rgba(255,255,255,0.85);
    }

    .div-card-cta svg {
        transition: transform 0.25s ease;
    }

    .div-card:hover .div-card-cta svg {
        transform: translateX(4px);
    }

    .div-card-desc {
        font-size: 0.78rem;
        color: #374151;
        line-height: 1.5;
        margin-top: 0.35rem;
        flex: 1;
    }

    .div-card:hover .div-card-desc {
        color: rgba(255,255,255,0.88);
    }

    /* ── Division Detail Hero ── */
    .div-hero-split {
        position: relative;
        width: 100%;
        height: 100vh;
        min-height: 500px;
        overflow: hidden;
        display: flex;
        align-items: center;
    }

        .div-hero-split .div-back-btn {
            position: absolute;
            z-index: 10;
            top: 1.5rem;
            left: 5vw;
            color: #fff;
        }

            .div-hero-split .div-back-btn:hover {
                color: rgba(255,255,255,0.75);
            }

    .div-hero-split-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        filter: brightness(0.55);
    }

    .div-hero-split-card {
        position: relative;
        z-index: 2;
        margin-left: 5vw;
        margin-top: 4rem;
        background: rgba(255,255,255,0.96);
        border-radius: 16px;
        padding: 2.25rem 2rem;
        max-width: 680px;
        width: 58%;
        box-shadow: 0 16px 60px rgba(0,0,0,0.35);
        overflow-y: auto;
        max-height: 80vh;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .div-split-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a2332;
        margin: 0 0 0.75rem;
    }

    .div-split-desc {
        font-size: 0.88rem;
        color: #444;
        line-height: 1.7;
        margin: 0 0 0.6rem;
    }

    .div-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.82rem;
        font-weight: 600;
        color: #1a6abf;
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
        transition: gap 0.2s ease, color 0.2s ease;
    }

        .div-back-btn:hover {
            gap: 0.65rem;
            color: #0d4fa0;
        }

        .div-back-btn svg {
            transition: transform 0.2s ease;
        }

        .div-back-btn:hover svg {
            transform: translateX(-3px);
        }
        .div-back-btn svg {
            transition: transform 0.2s ease;
        }

        .div-back-btn:hover svg {
            transform: translateX(-3px);
        }

    /* ── Division Product Cards Grid (level 2) ── */
    /* Push product detail hero below navbar */
    .div-prd-detail-hero {
        padding-top: 5rem;
    }

    .div-back-btn {
        padding-top: 5rem;
    }

    /* Product title in black */
    .div-prd-detail-left h1 {
        color: #111827 !important;
    }
    .div-prd-cards-section {
        padding: 6rem 5vw 4rem;
        background: #f7f9fc;
    }

    .div-prd-cards-heading {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1a6abf;
        text-align: center;
        margin: 0 0 2rem;
    }

    .div-prd-cards-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .div-prd-card {
        position: relative;
        background: #fff;
        border: 1.5px solid #dde5f0;
        border-radius: 14px;
        overflow: hidden;
        aspect-ratio: 4/3;
        cursor: pointer;
        transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
    }

        .div-prd-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 14px 40px rgba(0,80,200,0.15);
            border-color: #1a6abf;
        }

        .div-prd-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: var(--bg);
            background-size: cover;
            background-position: center;
            opacity: 0;
            transition: opacity 0.35s ease;
            filter: blur(1px);
        }

        .div-prd-card:hover::before {
            opacity: 1;
        }

    .div-prd-card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(150deg, rgba(8,45,110,0.80) 0%, rgba(0,110,210,0.68) 100%);
        opacity: 0;
        transition: opacity 0.35s ease;
        z-index: 1;
    }

    .div-prd-card:hover .div-prd-card-overlay {
        opacity: 1;
    }

    .div-prd-card-title {
        position: absolute;
        z-index: 2;
        top: 50%;
        left: 0;
        width: 100%;
        transform: translateY(-50%);
        padding: 0 1.25rem;
        font-size: 1rem;
        font-weight: 700;
        color: #1a6abf;
        text-align: center;
        line-height: 1.35;
        transition: color 0.3s ease;
    }

    .div-prd-card:hover .div-prd-card-title {
        color: #fff;
    }

    /* ── Product Detail View (level 3) ── */
    .div-prd-detail-wrap {
        background: #fff;
    }

    .div-prd-detail-hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        padding: 8rem 7vw 2.5rem;
        max-width: 1300px;
        margin: 0 auto;
        align-items: start;
    }
    .div-prd-detail-left h1 {
        font-size: 1.9rem;
        font-weight: 800;
        color: #111827;
        line-height: 1.2;
        margin: 0 0 1rem;
    }

    .div-prd-detail-left .prd-content p {
        font-size: 0.875rem;
        color: #374151;
        line-height: 1.75;
        margin: 0 0 0.85rem;
    }

    .div-prd-detail-left .prd-content ul {
        font-size: 0.875rem;
        color: #374151;
        line-height: 1.75;
        padding-left: 1.25rem;
        margin: 0 0 0.85rem;
    }

    .div-prd-detail-left .prd-content li {
        margin-bottom: 0.25rem;
    }

    .div-prd-detail-left .prd-content h4 {
        font-size: 0.9rem;
        font-weight: 700;
        color: #111827;
        margin: 1rem 0 0.4rem;
    }

    .div-prd-detail-left .prd-content table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.78rem;
        margin-top: 0.5rem;
    }

        .div-prd-detail-left .prd-content table th,
        .div-prd-detail-left .prd-content table td {
            border: 1px solid #e5e7eb;
            padding: 0.4rem 0.6rem;
            text-align: center;
        }

        .div-prd-detail-left .prd-content table th {
            background: #f3f4f6;
            font-weight: 700;
        }
    /* Hide inline media in left — shown on right */
    .div-prd-detail-left .prd-inline-media {
        display: none;
    }

    .div-prd-detail-right {
        position: sticky;
        top: 80px;
    }

        .div-prd-detail-right img {
            width: 100%;
            aspect-ratio: 4/3;
            object-fit: cover;
            border-radius: 16px;
            box-shadow: 0 8px 40px rgba(0,0,0,0.12);
        }

    /* Prev / Next nav for sub-products */
    .div-prd-subnav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 5vw;
        max-width: 1300px;
        margin: 0 auto;
        border-top: 1px solid #e5e7eb;
    }

    .div-prd-subnav-info {
        font-size: 0.8rem;
        color: #6b7280;
        font-weight: 600;
    }

    .div-prd-subnav-btns {
        display: flex;
        gap: 0.75rem;
    }

    .div-prd-subnav-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1rem;
        border: 1.5px solid #dde5f0;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 600;
        color: #374151;
        background: #fff;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .div-prd-subnav-btn:hover:not(:disabled) {
            background: #eff6ff;
            border-color: #1a6abf;
            color: #1a6abf;
        }

        .div-prd-subnav-btn:disabled {
            opacity: 0.35;
            cursor: default;
        }

    /* Sub-product label above title */
    .div-prd-parent-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #1a6abf;
        margin: 0 0 0.5rem;
    }

    /* Accordion */
    .prd-accordion {
        margin-top: 12px;
    }

    .prd-acc-item {
        border-bottom: 1px solid #e5e7eb;
    }

    .prd-acc-btn {
        width: 100%;
        background: none;
        border: none;
        text-align: left;
        padding: 0.75rem 0;
        font-size: 0.85rem;
        font-weight: 600;
        color: #111827;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
    }

        .prd-acc-btn:hover {
            color: #1a6abf;
        }

        .prd-acc-btn span {
            font-size: 1.1rem;
            line-height: 1;
            flex-shrink: 0;
        }

    .prd-acc-body {
        display: none;
        padding: 0 0 0.75rem;
        font-size: 0.83rem;
        color: #374151;
        line-height: 1.7;
    }

        .prd-acc-body.open {
            display: block;
        }
   
    /* ── Responsive ── */
    @@media (max-width: 1024px) {
        .div-card-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 700px) {
        .div-card-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 420px) {
        .div-card-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 960px) {
        .div-hero-split-card {
            width: 70%;
        }
    }

    @@media (max-width: 620px) {
        .div-hero-split {
            height: auto;
            flex-direction: column;
            align-items: stretch;
        }

        .div-hero-split-img {
            position: static;
            height: 260px;
            width: 100%;
            filter: brightness(1);
        }

        .div-hero-split-card {
            margin: 0;
            width: 100%;
            max-width: 100%;
            border-radius: 0;
            box-shadow: none;
            border-top: 3px solid #1a6abf;
            max-height: none;
        }

        .div-prod-hero {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .div-prod-hero-right {
            display: none;
        }
    }

    @@media (max-width: 960px) {
        .div-prd-cards-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 560px) {
        .div-prd-cards-grid {
            grid-template-columns: 1fr 1fr;
        }

        .div-prd-detail-hero {
            grid-template-columns: 1fr;
        }

        .div-prd-detail-right {
            display: none;
        }
    }
    /* ── Thumbnail strip ── */
    .prd-thumb-strip {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-top: 1.25rem;
    }

    .prd-thumb {
        width: 80px;
        height: 60px;
        object-fit: cover;
        border-radius: 8px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: border-color 0.2s ease, opacity 0.2s ease;
        opacity: 0.65;
    }

        .prd-thumb:hover {
            opacity: 1;
        }

        .prd-thumb.active {
            border-color: #1a6abf;
            opacity: 1;
        }

    /* ── Fullscreen lightbox ── */
    #imgLightbox {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.92);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: zoom-out;
    }

    #imgLightboxImg {
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
        border-radius: 8px;
        cursor: default;
    }

    #imgLightboxClose {
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        background: rgba(255,255,255,0.15);
        border: none;
        color: #fff;
        font-size: 1.4rem;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
    }

        #imgLightboxClose:hover {
            background: rgba(255,255,255,0.3);
        }

    .prd-thumb-strip {
        display: none !important;
    }

    body.on-detail-page .nd-nav a,
    body.on-detail-page .nd-nav-link,
    body.on-detail-page .navbar a,
    body.on-detail-page nav a,
    body.on-detail-page .nav-link,
    body.on-detail-page header a {
        color: #111827 !important;
    }

    body.on-detail-page .nd-logo,
    body.on-detail-page .navbar-brand {
        color: #111827 !important;
    }
</style>

<!-- ═══ PAGE HERO ═══ -->
<div class="nd-hero" id="pageHero">
    <img src="~/images/DivisionsBanner1.png" alt="Divisions" class="nd-hero-img" />
    <div class="nd-hero-overlay">
        <div class="tk-container nd-hero-content">
          
            <h1 class="nd-hero-title">Our Business</h1>
            <p class="nd-hero-sub">Engineering solutions across industries — delivered globally.</p>
        </div>
    </div>
</div>

