@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const items = document.querySelectorAll('.nd-item[data-target]');
            const panels = document.querySelectorAll('.nd-panel');

            function switchPanel(target) {
                items.forEach(i => i.classList.remove('active'));
                panels.forEach(p => p.classList.remove('active'));
                const activeItem = document.querySelector(`.nd-item[data-target="${target}"]`);
                const activePanel = document.querySelector(`.nd-panel[data-section="${target}"]`);
                if (activeItem) activeItem.classList.add('active');
                if (activePanel) activePanel.classList.add('active');
            }

            // Sidebar click → switch panel
            items.forEach(item => {
                item.addEventListener('click', () => switchPanel(item.dataset.target));
            });

            // ✅ Check URL hash first, otherwise default to intro
            const hash = window.location.hash.replace('#', '');
            if (hash) {
                switchPanel(hash);
            } else {
                switchPanel('intro');
            }
        });

        // Board accordion
        document.querySelectorAll('.board-expand-header').forEach(header => {
            header.addEventListener('click', () => {
                header.closest('.board-expandable').classList.toggle('open');
            });
        });
    </script>
}

