﻿@{
ViewData["Title"] = "TKIL Industries";
}

<section class="hero-section">
    <!-- Your 6 Sliders -->
    <div class="hero-bg">
        <div class="bg-slide active" style="background-image: url('/images/Slider1.jpg');"></div>
        <div class="bg-slide" style="background-image: url('/images/Slider2.jpg');"></div>
        <div class="bg-slide" style="background-image: url('/images/Slider3.jpg');"></div>
        <div class="bg-slide" style="background-image: url('/images/Slider4.jpg');"></div>
        <div class="bg-slide" style="background-image: url('/images/Slider5.jpg');"></div>
        <div class="bg-slide" style="background-image: url('/images/Slider6.jpg');"></div>
    </div>

    <!-- Dark Overlay -->
    <div class="hero-overlay"></div>

    <!-- TWO-COLUMN LAYOUT -->
    <div class="hero-layout">
        <!-- LEFT COLUMN: Text + CTA + Numbers -->
        <div class="hero-left">
            <h1 class="hero-title">Engineering Excellence</h1>
            <h2 class="hero-subtitle">Delivered Globally</h2>
            <p class="hero-description">Leading EPC for power, industrial, and infrastructure projects worldwide</p>

            <div class="hero-buttons">
                <a href="/Home/Products" class="btn-primary">Explore Products</a>
                <a href="/Home/Contact" class="btn-secondary">Get in Touch</a>
            </div>

            <!-- 4 NUMBERS BELOW CTA -->
            <div class="hero-stats-below">
                <div class="stat-item">
                    <span class="stat-number" data-target="230">+</span>
                    <span class="stat-label">EPC Projects</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-target="50">+</span>
                    <span class="stat-label">Countries</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-target="2600">+</span>
                    <span class="stat-label">Employees</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-target="10000">+</span>
                    <span class="stat-label">Contract Workers</span>
                </div>
            </div>

        </div>

        <!-- RIGHT COLUMN: Visual balance -->
        <div class="hero-right">
            <!-- Empty -->
        </div>
    </div>
</section>
<!-- Business Units Section - Rotating Donut -->
<section class="business-units-section">
    <div class="business-container">
        <!-- LEFT: Rotating Donut -->
        <div class="donut-wrapper">
            <div class="donut-container" id="businessWheel">

                <div class="unit-item active" data-index="0"
                     data-title="Sugar, Cogen & Bio-chemicals"
                     data-description="For over seventy years, TKIL Industries has been a pioneer in providing innovative, turnkey solutions to the sugar industry, including sugar refineries and cogen plants."
                     data-link="/Home/Divisions#sugar">
                    <img src="/images/business/sugar.jpg" alt="Sugar, Cogen & Bio-chemicals">
                </div>

                <div class="unit-item" data-index="1"
                     data-title="Mining, Material Handling & BOP"
                     data-description="TKIL Industries is a technologically driven engineering powerhouse, with exceptional contributions in Mining, Bulk Material Handling and Comminution Systems."
                     data-link="/Home/Divisions#mining">
                    <img src="/images/business/mining.jpg" alt="Mining & Material Handling">
                </div>

                <div class="unit-item" data-index="2"
                     data-title="Cement Plants & Equipment"
                     data-description="One of the world's leading cement and mining technology companies, manufacturing and commissioning integrated cement plants for more than 35 years."
                     data-link="/Home/Divisions#cement">
                    <img src="/images/business/cement.jpg" alt="Cement Plants">
                </div>

                <div class="unit-item" data-index="3"
                     data-title="Energy Business (Boiler & Power Plants)"
                     data-description="Long established in design, manufacture, supply, installation and commissioning of steam and power generation plants."
                     data-link="/Home/Divisions#energy">
                    <img src="/images/business/energy.jpg" alt="Energy Business">
                </div>

                <div class="unit-item" data-index="4"
                     data-title="Service Business"
                     data-description="Our 360° service program supports customers throughout the life cycle of their assets — spare parts, O&M, field service, revamps and rejuvenation."
                     data-link="/Home/Divisions#service">
                    <img src="/images/business/services.jpg" alt="Service Business">
                </div>

                <div class="unit-item" data-index="5"
                     data-title="Green Hydrogen Business"
                     data-description="At the forefront of India's green energy transition through strategic partnership with SoHHytec SA, Switzerland."
                     data-link="/Home/Divisions#green-hydrogen">
                    <img src="/images/business/green-hydrogen.jpg" alt="Green Hydrogen">
                </div>

                <div class="unit-item" data-index="6"
                     data-title="Battery & Energy Storage"
                     data-description="Strategic partnership with Germany's HOPPECKE Batterie Systeme GmbH delivering advanced Railway Battery Systems for India's rail sector."
                     data-link="/Home/Divisions#battery">
                    <img src="/images/business/battery.jpg" alt="Battery & Energy Storage">
                </div>

                <div class="unit-item" data-index="7"
                     data-title="Infrastructure Solutions"
                     data-description="Comprehensive infrastructure development solutions leveraging decades of engineering excellence."
                     data-link="/Home/Divisions">
                    <img src="/images/business/biochemicas.jpg" alt="Infrastructure">
                </div>

            </div>

            <!-- Center Hub -->
            <div class="center-hub">
                <span>BUSINESS<br>SERVICES</span>
            </div>
        </div>

        <!-- RIGHT: Content Display -->
        <div class="unit-content">
            <span class="section-tag">OUR EXPERTISE</span>
            <h2 class="content-title" id="unitTitle">Sugar, Cogen & Bio-chemicals</h2>
            <p class="content-description" id="unitDescription">
                For over seventy years, TKIL Industries has been a pioneer in providing innovative, turnkey solutions to the sugar industry...
            </p>
            <a href="/Home/Divisions#sugar" class="know-more-btn" id="unitLink">Know More</a>
        </div>
    </div>
</section>
<!-- Global Presence Section -->
<section class="global-presence-section">
    <div class="global-presence-container">
        <div class="global-presence-header">
            <h2 class="global-presence-title">Our Global presence</h2>
        </div>
        <div class="global-presence-image-wrapper">
            <img src="~/images/global-presence.jpg" alt="TKIL Global Presence Map" class="global-presence-image" />
        </div>
    </div>
</section>
<script>
         document.querySelectorAll('.unit-item').forEach(item => {
        item.addEventListener('click', () => {
            document.querySelectorAll('.unit-item').forEach(i => i.classList.remove('active'));
            item.classList.add('active');
            document.getElementById('unitTitle').textContent = item.dataset.title;
            document.getElementById('unitDescription').textContent = item.dataset.description;
            document.getElementById('unitLink').href = item.dataset.link;
        });
    });
</script>