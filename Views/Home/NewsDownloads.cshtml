<!-- Hero -->
<div class="nd-hero">
    <img src="~/images/company/2.jpg" alt="TKIL" class="nd-hero-img" />
    <div class="nd-hero-overlay">
        <div class="tk-container nd-hero-content">
            <span class="nd-eyebrow">Media Center</span>
