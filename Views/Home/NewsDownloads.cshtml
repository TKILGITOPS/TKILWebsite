<script>
    (function () {
        // Smooth scroll for nav links
        document.querySelectorAll('.nd-nav-link').forEach(function (link) {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                var target = document.querySelector('#' + this.dataset.section);
                if (target) {
                    var nav = document.getElementById('ndNav');
                    var offset = nav ? nav.offsetHeight : 52;
                    var top = target.getBoundingClientRect().top + window.scrollY - offset - 8;
                    window.scrollTo({ top: top, behavior: 'smooth' });
                }
            });
        });

        // Active state on scroll
        var sections = document.querySelectorAll('.nd-section[id]');
        var navLinks = document.querySelectorAll('.nd-nav-link');
        var navH = 52;

        function updateActive() {
            var scrollY = window.scrollY + navH + 40;
            var current = '';
            sections.forEach(function (sec) {
                if (sec.offsetTop <= scrollY) {
                    current = sec.id;
                }
            });
            navLinks.forEach(function (lnk) {
                lnk.classList.toggle('active', lnk.dataset.section === current);
            });
        }

        window.addEventListener('scroll', updateActive, { passive: true });
        updateActive();
    })();
</script>
