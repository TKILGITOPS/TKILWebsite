            <p class="nd-hero-sub">Awards · Press Releases · Exhibitions · Brochures · Safety</p>
        </div>
    </div>
</div>

<!-- Full page layout -->
<div class="nd-page">
    <div class="tk-container nd-flex">

        <!-- LEFT: Sidebar -->
