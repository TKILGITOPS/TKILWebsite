                    </li>
                    <li>
                        <a href="~/pdf/Press Release_TKIL Industries Demonstrates Advanced MACS at EXCON 2025 (002).pdf" target="_blank">
                            <div class="nd-press-item">
                                <span class="nd-press-date">2025-12-09</span>
                                <span class="nd-press-title">Press Release_EXCON 2025</span>
                                <span class="nd-press-icon">↗</span>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a href="~/pdf/Press Note_TKIL Industries Partners with Germany-based company 2G Energy International.pdf" target="_blank">
                            <div class="nd-press-item">
                                <span class="nd-press-date">2025-10-13</span>
                                <span class="nd-press-title">Press Release_TKIL Industries Partners with Germany-based company 2G Energy International</span>
                                <span class="nd-press-icon">↗</span>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a href="~/pdf/Press Release_ TKIL Industries and HOPPECKE Forms Strategic Partnership 2025.05.27.pdf" target="_blank">
                            <div class="nd-press-item">
                                <span class="nd-press-date">2025-05-27</span>
                                <span class="nd-press-title">Press Release_TKIL Industries and HOPPECKE Forms Strategic Partnership</span>
                                <span class="nd-press-icon">↗</span>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a href="~/pdf/Press Release_ TKIL Industries  KIS Group Association 2025.04.01.pdf" target="_blank">
                            <div class="nd-press-item">
                                <span class="nd-press-date">2025-04-01</span>
                                <span class="nd-press-title">Press Release_TKIL Industries KIS Group Association</span>
                                <span class="nd-press-icon">↗</span>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a href="~/pdf/TKIL Hyderabad Five Star OSH Audit 2025.pdf" target="_blank">
                            <div class="nd-press-item">
                                <span class="nd-press-date">March 2025</span>
                                <span class="nd-press-title">Press Release_British Council Safety Hyderabad</span>
                                <span class="nd-press-icon">↗</span>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a href="~/pdf/Press Release- Odisha Mining.pdf" target="_blank">
                            <div class="nd-press-item">
                                <span class="nd-press-date">2025-03-10</span>
                                <span class="nd-press-title">Press Release_Odisha Mining Expo 2025</span>
                                <span class="nd-press-icon">↗</span>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a href="~/pdf/Press Release_ British Council safety.pdf" target="_blank">
                            <div class="nd-press-item">
                                <span class="nd-press-date">2025-01-22</span>
                                <span class="nd-press-title">Press Release_British Council Safety</span>
                                <span class="nd-press-icon">↗</span>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a href="~/pdf/Press Release Green Hydrogen announcement.pdf" target="_blank">
                            <div class="nd-press-item">
                                <span class="nd-press-date">2024-12-03</span>
                                <span class="nd-press-title">Press Release_Green Hydrogen Announcement</span>
                                <span class="nd-press-icon">↗</span>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a href="~/pdf/Press_Release_Company_name_to_TKIL_Industries.pdf" target="_blank">
                            <div class="nd-press-item">
                                <span class="nd-press-date">2024-07-19</span>
                                <span class="nd-press-title">Press Release_Name Change to TKIL Industries Pvt. Ltd.</span>
                                <span class="nd-press-icon">↗</span>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a href="~/pdf/Press Release_Change of tkIL shareholding structure.pdf" target="_blank">
