@{
    ViewData["Title"] = "News & Downloads";
}

<style>
    /* ═══════════════════════════════════════════════════
           NEWS & DOWNLOADS — FULL-SCREEN LAYOUT
           All classes prefixed .nd- to avoid conflicts
        ═══════════════════════════════════════════════════ */

    *, *::before, *::after {
        box-sizing: border-box;
    }

    /* Reset page body to be full-width */
    .nd-page-wrap {
        width: 100%;
        min-height: 100vh;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        background: #F0F4F8;
        color: #1F2937;
    }

    /* ── HERO ─────────────────────────────────────────── */
    .nd-hero {
        position: relative;
        width: 100%;
        height: 340px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
    }

    .nd-hero-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 40%;
        filter: brightness(0.45) saturate(0.7);
    }

    .nd-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to top, rgba(0, 18, 45, 0.96) 0%, rgba(0, 18, 45, 0.55) 50%, rgba(0, 30, 60, 0.2) 100% );
    }

    .nd-hero-body {
        position: relative;
        z-index: 2;
        width: 100%;
        padding: 0 5vw 2.5rem;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .nd-hero-eyebrow {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: #00A3D9;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .nd-hero-eyebrow::before {
            content: '';
            display: block;
            width: 20px;
            height: 2px;
            background: #00A3D9;
        }

    .nd-hero-title {
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-weight: 800;
        color: #fff;
        line-height: 1.05;
        letter-spacing: -0.03em;
        margin: 0;
    }

    .nd-hero-sub {
        font-size: 0.85rem;
        color: rgba(255,255,255,0.55);
        margin-top: 0.5rem;
        letter-spacing: 0.05em;
    }

    .nd-hero-stats {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .nd-stat {
        text-align: right;
    }

    .nd-stat-num {
        display: block;
        font-size: 2rem;
        font-weight: 800;
        color: #00A3D9;
        line-height: 1;
        letter-spacing: -0.03em;
    }

    .nd-stat-label {
        display: block;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.45);
        margin-top: 2px;
    }

    /* ── STICKY NAV ───────────────────────────────────── */
    .nd-nav {
        position: sticky;
        top: 0;
        z-index: 100;
        width: 100%;
        background: #fff;
        border-bottom: 1px solid #E2E8F0;
        display: flex;
        align-items: center;
        padding: 0 5vw;
        height: 52px;
        gap: 0;
        box-shadow: 0 1px 12px rgba(0,0,0,0.07);
    }

    .nd-nav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        height: 100%;
        padding: 0 1.2rem;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #64748B;
        text-decoration: none;
        border-bottom: 3px solid transparent;
        transition: color 0.2s, border-color 0.2s;
        white-space: nowrap;
    }

        .nd-nav-link:hover,
        .nd-nav-link.active {
            color: #0079A7;
            border-bottom-color: #0079A7;
        }

    /* ── MAIN BODY ────────────────────────────────────── */
    .nd-body {
        width: 100%;
    }

    /* ── SECTION WRAPPER ─────────────────────────────── */
    .nd-section {
        width: 100%;
        padding: 4rem 5vw;
    }

        .nd-section:nth-child(even) {
            background: #fff;
        }

        .nd-section:nth-child(odd) {
            background: #F0F4F8;
        }

    .nd-section-head {
        margin-bottom: 2.5rem;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .nd-section-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: #0079A7;
        margin-bottom: 0.5rem;
    }

        .nd-section-tag::before {
            content: '';
            display: block;
            width: 18px;
            height: 2px;
            background: #0079A7;
            border-radius: 2px;
        }

    .nd-section-title {
        font-size: clamp(1.5rem, 2.5vw, 2.2rem);
        font-weight: 800;
        color: #0F172A;
        line-height: 1.1;
        letter-spacing: -0.025em;
        margin: 0;
    }

    .nd-section-desc {
        font-size: 0.9rem;
        color: #64748B;
        margin-top: 0.4rem;
        max-width: 520px;
    }

    /* ── AWARDS ───────────────────────────────────────── */
    .nd-award-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .nd-award-card {
        background: #fff;
        border: 1px solid #E2E8F0;
        padding: 1.75rem;
        position: relative;
        overflow: hidden;
        transition: box-shadow 0.3s, transform 0.3s;
    }

        .nd-award-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #0079A7, #00A3D9);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.35s ease;
        }

        .nd-award-card:hover {
            box-shadow: 0 8px 32px rgba(0,121,167,0.12);
            transform: translateY(-3px);
        }

            .nd-award-card:hover::before {
                transform: scaleX(1);
            }

    .nd-award-year {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #0079A7;
        background: rgba(0,121,167,0.08);
        display: inline-block;
        padding: 3px 10px;
        margin-bottom: 1rem;
    }

    .nd-award-card h3 {
        font-size: 1rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 0.5rem;
        line-height: 1.3;
    }

    .nd-award-card p {
        font-size: 0.85rem;
        color: #64748B;
        line-height: 1.6;
        margin: 0;
    }

    /* ── PRESS RELEASES ──────────────────────────────── */
    .nd-press-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

        .nd-press-list li a {
            display: grid;
            grid-template-columns: 110px 1fr 36px;
            align-items: center;
            gap: 1.5rem;
            padding: 1.1rem 1.5rem;
            background: #fff;
            border: 1px solid #E2E8F0;
            text-decoration: none;
            transition: background 0.2s, border-color 0.2s, transform 0.2s;
            position: relative;
            overflow: hidden;
        }

            .nd-press-list li a::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0;
                bottom: 0;
                width: 3px;
                background: #0079A7;
                transform: scaleY(0);
                transform-origin: bottom;
                transition: transform 0.25s ease;
            }

            .nd-press-list li a:hover {
                background: #F8FAFF;
                border-color: #BAD4E8;
                transform: translateX(4px);
            }

                .nd-press-list li a:hover::before {
                    transform: scaleY(1);
                }

    .nd-press-date {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: #0079A7;
        white-space: nowrap;
    }

    .nd-press-title {
        font-size: 0.88rem;
        font-weight: 500;
        color: #1E293B;
        line-height: 1.4;
    }

    .nd-press-arrow {
        width: 32px;
        height: 32px;
        border: 1.5px solid #CBD5E1;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94A3B8;
        flex-shrink: 0;
        transition: all 0.2s;
        justify-self: end;
    }

    .nd-press-list li a:hover .nd-press-arrow {
        background: #0079A7;
        border-color: #0079A7;
        color: #fff;
    }

    /* ── EXHIBITIONS ─────────────────────────────────── */
    .nd-expo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    .nd-expo-card {
        background: #fff;
        border: 1px solid #E2E8F0;
        padding: 2rem;
        position: relative;
        overflow: hidden;
        transition: box-shadow 0.3s, transform 0.3s;
    }

        .nd-expo-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #0079A7, #00A3D9);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.35s;
        }

        .nd-expo-card:hover {
            box-shadow: 0 8px 32px rgba(0,121,167,0.12);
            transform: translateY(-3px);
        }

            .nd-expo-card:hover::after {
                transform: scaleX(1);
            }

    .nd-expo-year {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        color: #0079A7;
        background: rgba(0,121,167,0.08);
        display: inline-block;
        padding: 3px 10px;
        margin-bottom: 1rem;
    }

    .nd-expo-card h3 {
        font-size: 1.05rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 0.5rem;
    }

    .nd-expo-card p {
        font-size: 0.85rem;
        color: #64748B;
        line-height: 1.65;
        margin: 0;
    }

    /* ── BROCHURES ────────────────────────────────────── */
    .nd-brochure-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.25rem;
    }

    .nd-brochure-card {
        background: #fff;
        border: 1px solid #E2E8F0;
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: box-shadow 0.3s, transform 0.3s;
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

        .nd-brochure-card::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #0079A7, #00A3D9);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.35s;
        }

        .nd-brochure-card:hover {
            box-shadow: 0 8px 32px rgba(0,121,167,0.12);
            transform: translateY(-3px);
        }

            .nd-brochure-card:hover::before {
                transform: scaleX(1);
            }

    .nd-brochure-icon {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, #0079A7, #00A3D9);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .nd-brochure-icon svg {
            width: 22px;
            height: 22px;
            color: #fff;
        }

    .nd-brochure-card h3 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0;
        line-height: 1.3;
        flex: 1;
    }

    .nd-brochure-card p {
        font-size: 0.8rem;
        color: #64748B;
        line-height: 1.55;
        margin: 0;
    }

    .nd-dl-btn {
