                    <span>Exhibition</span>
                    <svg class="nd-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" /></svg>
                </li>
                <li class="nd-item" data-target="brochures">
                   
                    <span>Brochures</span>
                    <svg class="nd-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" /></svg>
                </li>
                <li class="nd-item" data-target="video">
             
                    <span>Safety Video</span>
                    <svg class="nd-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" /></svg>
                </li>
            </ul>
        </aside>

        <!-- RIGHT: Content -->
        <main class="nd-content-area" id="ndContent">

            <!-- Awards -->
            <div class="nd-panel active" data-section="awards">
                <div class="nd-panel-header">
                    <span class="nd-panel-tag">Recognition</span>
                    <h2>Awards &amp; Recognition</h2>
                    <p>TKIL Industries has been recognized globally for engineering excellence and innovation across multiple decades.</p>
                </div>
                <div class="nd-cards">
                    <div class="nd-card">
                        <div class="nd-card-year">2025</div>
                        <h3>Best Engineering Firm</h3>
                        <p>Awarded for outstanding EPC project delivery in South Asia.</p>
                    </div>
                    <div class="nd-card">
                        <div class="nd-card-year">2024</div>
                        <h3>Innovation Award</h3>
                        <p>Recognized for pioneering sustainable bio-chemical plant design.</p>
                    </div>
                    <div class="nd-card">
                        <div class="nd-card-year">2023</div>
                        <h3>Excellence in Manufacturing</h3>
                        <p>Felicitated for consistent quality in large-scale manufacturing projects.</p>
                    </div>
                </div>
            </div>

            <!-- Press -->
            <div class="nd-panel" data-section="press">
                <div class="nd-panel-header">
                    <span class="nd-panel-tag">Media</span>
                    <h2>Press Releases</h2>
                    <p>Latest announcements and media coverage from TKIL Industries.</p>
                </div>

