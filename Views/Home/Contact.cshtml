<style>
/* ════════════════════════════════════════════
   CONTACT PAGE  —  ctc- prefix
════════════════════════════════════════════ */

.ctc-page {
    background: #f8fafc;
    padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 6vw, 6rem);
}

.ctc-container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 clamp(1rem, 5vw, 5rem);
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
}

/* ── Sidebar ──────────────────────────────── */
.ctc-sidebar {
    position: sticky;
    top: 90px;
}

.ctc-sidebar-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #94a3b8;
    margin: 0 0 0.85rem;
}

.ctc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
}

/* Group label between items */
.ctc-group-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #94a3b8;
    padding: 1rem 0 0.4rem 1rem;
    border-top: 1px solid #e2e8f0;
    margin-top: 0.25rem;
}

/* ── Each selector item ───────────────────── */
.ctc-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1rem;
    cursor: pointer;
    position: relative;
    border-bottom: 1px solid #f1f5f9;
    transition: background 0.18s ease, color 0.18s ease;
    border-radius: 0;

    /* Clip path for arrow chevron when active */
    --ctc-active-bg: #0d2d44;
}

.ctc-item:hover {
    background: #f0f8fc;
    color: #0079A7;
}

/* Active = dark chevron arrow (like reference) */
.ctc-item.ctc-active {
    background: var(--ctc-active-bg);
    color: #ffffff;

    /* Chevron arrow on right side using clip-path */
    clip-path: polygon(0 0, calc(100% - 18px) 0, 100% 50%, calc(100% - 18px) 100%, 0 100%);
    padding-right: 2rem;
    border-bottom-color: transparent;
    border-radius: 0;
}

.ctc-item.ctc-active:hover {
    background: #162f4a;
    color: #ffffff;
}

.ctc-item-text {
    font-size: clamp(0.82rem, 1vw, 0.92rem);
    font-weight: 500;
    line-height: 1.35;
    flex: 1;
}

.ctc-item.ctc-active .ctc-item-text {
    font-weight: 600;
}

/* Default badge */
.ctc-badge {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    background: rgba(255,255,255,0.2);
    color: #ffffff;
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
}

/* Sub-items (Divisions) — indented with left tick */
.ctc-item.ctc-sub {
    padding-left: 1.75rem;
}

.ctc-sub-tick {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #cbd5e1;
    flex-shrink: 0;
    transition: background 0.18s ease;
}

.ctc-item.ctc-sub:hover .ctc-sub-tick {
    background: #0079A7;
}

.ctc-item.ctc-sub.ctc-active .ctc-sub-tick {
    background: rgba(255,255,255,0.7);
}

/* ── Panels ───────────────────────────────── */
.ctc-content {
    min-height: 300px;
}

.ctc-panel {
    display: none;
    animation: ctcFadeIn 0.3s ease;
}

.ctc-panel.ctc-panel-active {
    display: block;
}

@@keyframes ctcFadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
}

.ctc-panel-header {
    margin-bottom: 1.75rem;
}

.ctc-panel-tag {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0079A7;
    background: #e0f2fe;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 0.6rem;
}

.ctc-panel-title {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    color: #0d2d44;
    margin: 0;
    letter-spacing: -0.02em;
}

/* ── Cards grid ───────────────────────────── */
.ctc-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
}

.ctc-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 1.5rem;
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
}

.ctc-card:hover {
    box-shadow: 0 8px 28px rgba(0, 121, 167, 0.12);
    transform: translateY(-3px);
    border-color: #b8d9ed;
}

.ctc-card-top {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    margin-bottom: 1.1rem;
    padding-bottom: 1.1rem;
    border-bottom: 1px solid #f1f5f9;
}

.ctc-card-icon {
    width: 42px;
    height: 42px;
    min-width: 42px;
    border-radius: 10px;
    background: linear-gradient(135deg, #0079A7, #00A3D9);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    margin-top: 2px;
}

.ctc-card-icon svg {
    width: 20px;
    height: 20px;
}

.ctc-card-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0d2d44;
    margin: 0 0 0.15rem;
}

.ctc-card-loc {
    font-size: 0.78rem;
    color: #64748b;
    margin: 0;
}

/* Detail rows */
.ctc-card-details {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
}

.ctc-detail-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: #374151;
}

.ctc-detail-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #94a3b8;
    min-width: 46px;
    flex-shrink: 0;
}

.ctc-detail-row a {
    color: #0079A7;
    text-decoration: none;
    transition: color 0.15s ease;
    word-break: break-all;
}

.ctc-detail-row a:hover {
    color: #005f85;
    text-decoration: underline;
}

/* ── Responsive ───────────────────────────── */
@@media (max-width: 860px) {
    .ctc-container {
        grid-template-columns: 1fr;
    }

    .ctc-sidebar {
        position: static;
    }

    /* On mobile sidebar becomes horizontal scrollable row */
    .ctc-list {
        flex-direction: row;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        gap: 0;
        background: #ffffff;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        padding: 0;
    }

    .ctc-list::-webkit-scrollbar { display: none; }

    .ctc-group-label {
        display: none;
    }

    .ctc-item {
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 0.75rem 1rem;
        border-bottom: none;
        border-right: 1px solid #f1f5f9;
        white-space: nowrap;
        min-width: max-content;
        clip-path: none !important;
        border-radius: 0;
        gap: 0.25rem;
    }

    .ctc-item.ctc-active {
        clip-path: none !important;
        background: #0d2d44;
        border-bottom: 3px solid #0079A7;
        color: #ffffff;
        padding-right: 1rem;
    }

    .ctc-item.ctc-sub {
        padding-left: 1rem;
    }

    .ctc-sub-tick { display: none; }

    .ctc-badge { display: none; }

    .ctc-item-text {
        font-size: 0.78rem;
    }
}

@@media (max-width: 480px) {
    .ctc-cards {
        grid-template-columns: 1fr;
    }

    .ctc-panel-title {
        font-size: 1.3rem;
    }
}
</style>

<script>
(function () {
    const items = document.querySelectorAll('.ctc-item[data-panel]');
    const panels = document.querySelectorAll('.ctc-panel');

    items.forEach(function (item) {
        item.addEventListener('click', function () {
            // Remove active from all items
            items.forEach(function (i) { i.classList.remove('ctc-active'); });
            // Set active on clicked
            item.classList.add('ctc-active');

            // Hide all panels
            panels.forEach(function (p) { p.classList.remove('ctc-panel-active'); });
            // Show target panel
            var target = document.getElementById('panel-' + item.dataset.panel);
            if (target) { target.classList.add('ctc-panel-active'); }
        });
    });
})();
</script>
