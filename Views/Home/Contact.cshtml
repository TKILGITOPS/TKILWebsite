        background: #1a6abf;
    }

        .enq-btn-primary:hover {
            background: #0d4fa0;
        }

    #captchaCanvas {
        border-color: #e5e7eb;
    }

    .enq-captcha-refresh {
        color: #6b7280;
    }

        .enq-captcha-refresh:hover {
            color: #1a6abf;
        }
</style>

<script>
(function () {
    const items = document.querySelectorAll('.ctc-item[data-panel]');
    const panels = document.querySelectorAll('.ctc-panel');

    items.forEach(function (item) {
        item.addEventListener('click', function () {
            // Remove active from all items
            items.forEach(function (i) { i.classList.remove('ctc-active'); });
            // Set active on clicked
            item.classList.add('ctc-active');

            // Hide all panels
            panels.forEach(function (p) { p.classList.remove('ctc-panel-active'); });
            // Show target panel
            var target = document.getElementById('panel-' + item.dataset.panel);
            if (target) { target.classList.add('ctc-panel-active'); }
        });
    });
})();

   // ─── Division → Products ────────────────────────────────
    const divisionProducts = {
        "General"  : ["  None"  ],
        "Sugar Plants and machinery"  : [
            "   Refineries"   , "   Fiberizer"   , "   Shredder"   , "   Rotary Screen"   ,
            "   Two Roller Mill"   , "   Three Roller Mill"   , "   Four Roller Mill"   ,
            "   Five Roller Mill"   , "   Six Roller Mill"   , "   Juice Heater"   ,
            "   Rising Film Evaporator"   , "   Falling Film Evaporator"   ,
            "   Vaccum Pans"   , "   Crystallisers"   , "   Continuous Centrifugal"   ,
            "   Batch (Discontinuous) Centrifugal"   
        ],
        "Cement"  : [
            "  Raw Material Preparation"  , "  Clinker Production"  , "  Cement Manufacturing"  ,
            "  Factory Automation (Products Cement)"  , "  Grinding Plants for Ores and Minerals"  ,
            "  Pyroprocessing Systems"  , "  Factory Automation (Products Minerals)"  , "  Lime Kiln Plants"   
        ],
        "Mining & Bulk Material Handling"  : [
            "  Stackers"  , "  Bucket Wheel Reclaimers"  , "  Combined Stacker-Reclaimers"  ,
            "  Crushers"  , "  Feeders & Screens"  , "  Wagon Loading System"  , "  Wagon Tipplers"  ,
            "  Paddle Feeders"  , "  Process Technology"  , "  Type Ship Unloaders"  ,
            "  Long-Distance Curved Conveyors"  , "  Pipe Conveyors"  
        ],
        "Energy"  : [
            "  Complete Thermal Power Plants on EPC Basis"  , "  CFBC Boilers"  ,
            "  Stocker fired boilers"  , "  Waste Heat Recovery Boilers"  , "  Oil / Gas Fired Boilers"  
        ]
    };

    function updateProducts() {
        const Divisionselect = document.getElementById("division");
        const productSelect = document.getElementById("product");
        const selectedDivision = Divisionselect.value;

        productSelect.innerHTML = '<option value="">-- Select Product --</option>';

        if (selectedDivision && divisionProducts[selectedDivision]) {
            divisionProducts[selectedDivision].forEach(product => {
                const option = document.createElement("option");
                option.value = product;
                option.textContent = product;
                productSelect.appendChild(option);
            });
            productSelect.disabled = false;
        } else {
            productSelect.disabled = true;
        }
    }

    document.getElementById("division").addEventListener("change", updateProducts);
    updateProducts();

    // ─── Alphanumeric Captcha ───────────────────────────────
    let captchaText = "";

    function generateCaptcha() {
        const chars = "ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789";
        captchaText = "";
        for (let i = 0; i < 6; i++) {
            captchaText += chars[Math.floor(Math.random() * chars.length)];
        }

        const canvas = document.getElementById("captchaCanvas");
        const ctx = canvas.getContext("2d");
        const W = canvas.width;
        const H = canvas.height;

        // Background
        ctx.fillStyle = "#f5f0ea";
        ctx.fillRect(0, 0, W, H);

        // Noise dots
        for (let i = 0; i < 80; i++) {
            ctx.beginPath();
            ctx.arc(
                Math.random() * W,
                Math.random() * H,
                Math.random() * 1.5,
                0, Math.PI * 2
            );
            ctx.fillStyle = `rgba(${rand(100,180)},${rand(80,140)},${rand(60,120)},${Math.random().toFixed(2)})`;
            ctx.fill();
        }

        // Noise lines
        for (let i = 0; i < 4; i++) {
            ctx.beginPath();
            ctx.moveTo(Math.random() * W, Math.random() * H);
            ctx.lineTo(Math.random() * W, Math.random() * H);
            ctx.strokeStyle = `rgba(${rand(140,200)},${rand(100,160)},${rand(80,130)},0.4)`;
            ctx.lineWidth = 1;
            ctx.stroke();
        }

        // Draw each character individually with slight rotation & position variation
        const fonts = ["bold 22px Georgia", "bold 22px Arial", "bold 21px 'Times New Roman'"];
        const colors = ["#5a3020", "#7a4030", "#3a2e26", "#8b3e1f", "#4a3828", "#6b4535"];

        for (let i = 0; i < captchaText.length; i++) {
            ctx.save();
            const x = 12 + i * 21;
            const y = H / 2 + rand(-3, 5);
            ctx.translate(x, y);
            ctx.rotate((Math.random() - 0.5) * 0.5);
            ctx.font = fonts[Math.floor(Math.random() * fonts.length)];
            ctx.fillStyle = colors[Math.floor(Math.random() * colors.length)];
            ctx.fillText(captchaText[i], 0, 0);
            ctx.restore();
        }

        // Clear input and error
        document.getElementById("captchaAnswer").value = "";
        document.getElementById("captchaError").style.display = "none";
    }

    function rand(min, max) {
        return Math.floor(Math.random() * (max - min + 1)) + min;
    }

    function validateCaptcha() {
        const userAnswer = document.getElementById("captchaAnswer").value.trim();
        const errorEl = document.getElementById("captchaError");

        if (userAnswer.toLowerCase() !== captchaText.toLowerCase()) {
            errorEl.style.display = "block";
            generateCaptcha();
            return false;
        }

        errorEl.style.display = "none";
        return true;
    }

    document.getElementById("captchaRefresh").addEventListener("click", generateCaptcha);

    // ─── Form submit guard ──────────────────────────────────
    document.querySelector(".enq-form").addEventListener("submit", function (e) {
        if (!validateCaptcha()) {
            e.preventDefault();
        }
    });

    generateCaptcha();
</script>
