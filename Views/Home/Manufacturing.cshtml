@{
    ViewData["Title"] = "Manufacturing";
}

<!-- Hero — same ND style -->
<div class="nd-hero">
    <img src="~/images/company/2.jpg" alt="Manufacturing" class="nd-hero-img" />
    <div class="nd-hero-overlay">
        <div class="nd-hero-content">
            <span class="nd-eyebrow">Our Capabilities</span>
            <h1 class="nd-hero-title">Manufacturing</h1>
            <p class="nd-hero-sub">Seven decades of precision engineering and manufacturing excellence</p>
        </div>
    </div>
</div>

