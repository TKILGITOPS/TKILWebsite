@{
    ViewData["Title"] = "Products";
}

<div class="prd-page">

    <!-- ── HERO ── -->
    <div class="prd-hero">
        <img src="~/images/company/2.jpg" alt="Products Hero" class="prd-hero-img" />
        <div class="prd-hero-overlay"></div>
        <div class="prd-hero-text">
            <p class="prd-hero-eyebrow">Divisions</p>
            <h1 class="prd-hero-title">Products</h1>
            <p class="prd-hero-sub">Sugar · Mining · Cement · Energy</p>
        </div>
    </div>

    <!-- ── PHASE 1: 4 CARDS (no sidebar) ── -->
    <div class="prd-cards-phase" id="prdCardsPhase">
        <div class="prd-cards-body">

            <div class="prd-cards-grid">

                <div class="prd-cat-card" data-category="sugar">
                    <div class="prd-cat-card-img">
                        <img src="~/images/Divisions/sugar.jpg" alt="Sugar Plant" onerror="this.style.display='none'" />
                    </div>
                    <div class="prd-cat-card-body">
                        <h3>Sugar Plant and Machinery</h3>
                        <p>Turnkey solutions for sugar, cogen &amp; bio-chemical plants.</p>
                        <span class="prd-cat-card-btn">Explore Products →</span>
                    </div>
                </div>

                <div class="prd-cat-card" data-category="mining">
                    <div class="prd-cat-card-img">
                        <img src="~/images/Divisions/Mining - IEW.jpg" alt="Mining" onerror="this.style.display='none'" />
                    </div>
                    <div class="prd-cat-card-body">
                        <h3>Mining and Bulk Material Handling</h3>
                        <p>Heavy-duty systems for mining, crushing &amp; material transport.</p>
                        <span class="prd-cat-card-btn">Explore Products →</span>
                    </div>
                </div>

                <div class="prd-cat-card" data-category="cement">
                    <div class="prd-cat-card-img">
                        <img src="~/images/Divisions/wonder-cement-new.jpg" alt="Cement" onerror="this.style.display='none'" />
                    </div>
                    <div class="prd-cat-card-body">
                        <h3>Cement Plant and Machinery</h3>
                        <p>Advanced machinery for cement manufacturing &amp; processing.</p>
                        <span class="prd-cat-card-btn">Explore Products →</span>
                    </div>
                </div>

                <div class="prd-cat-card" data-category="energy">
                    <div class="prd-cat-card-img">
                        <img src="~/images/Divisions/energy.jpg" alt="Energy" onerror="this.style.display='none'" />
                    </div>
                    <div class="prd-cat-card-body">
                        <h3>Energy</h3>
                        <p>Power generation solutions built for performance &amp; reliability.</p>
                        <span class="prd-cat-card-btn">Explore Products →</span>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ── PHASE 2: SIDEBAR + CONTENT (hidden initially) ── -->
    <div class="prd-detail-phase" id="prdDetailPhase">
        <div class="prd-detail-inner">

            <!-- Sidebar -->
            <aside class="prd-sidebar">
                <p class="prd-sidebar-label">BROWSE BY SECTION</p>
                <ul class="prd-sidebar-list" id="prdSidebarList">
                    <!-- JS will inject items here based on selected category -->
                </ul>
                <div class="prd-sidebar-back" id="prdBackBtn">
                    ← Back to Products
                </div>
            </aside>

            <!-- Content -->
            <div class="prd-content" id="prdContent">
                <!-- JS will inject content here -->
            </div>

        </div>
    </div>

</div>

